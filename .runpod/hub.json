{
  "title": "LlamaCpp GGUF Worker",
  "description": "Serve any GGUF model from HuggingFace via llama.cpp with an OpenAI-compatible API. Supports GPU offloading, flash attention, quantized KV cache, and streaming.",
  "category": "llm",
  "env": [
    {
      "key": "HF_REPO_ID",
      "label": "HuggingFace Repository",
      "description": "HuggingFace repo containing the GGUF model (e.g. bartowski/Qwen_Qwen3-8B-GGUF)",
      "required": true,
      "type": "string"
    },
    {
      "key": "HF_FILENAME",
      "label": "GGUF Filename",
      "description": "Specific GGUF file to download. Leave blank to auto-detect the best Q4_K_M file.",
      "required": false,
      "type": "string"
    },
    {
      "key": "HF_TOKEN",
      "label": "HuggingFace Token",
      "description": "Auth token for gated models (optional)",
      "required": false,
      "type": "string"
    },
    {
      "key": "MODEL_NAME",
      "label": "Model Display Name",
      "description": "Name shown in /v1/models endpoint",
      "required": false,
      "default": "default",
      "type": "string"
    },
    {
      "key": "N_GPU_LAYERS",
      "label": "GPU Layers",
      "description": "Number of layers to offload to GPU (99 = all)",
      "required": false,
      "default": "99",
      "type": "string"
    },
    {
      "key": "CTX_SIZE",
      "label": "Context Size",
      "description": "Maximum context window size in tokens",
      "required": false,
      "default": "8192",
      "type": "string"
    },
    {
      "key": "N_PARALLEL",
      "label": "Parallel Slots",
      "description": "Number of concurrent inference slots",
      "required": false,
      "default": "1",
      "type": "string"
    },
    {
      "key": "FLASH_ATTN",
      "label": "Flash Attention",
      "description": "Enable flash attention (on/off/auto)",
      "required": false,
      "default": "on",
      "type": "string"
    },
    {
      "key": "KV_CACHE_TYPE",
      "label": "KV Cache Quantization",
      "description": "KV cache type: f16, f32, q8_0, q4_0, q4_1",
      "required": false,
      "default": "f16",
      "type": "string"
    },
    {
      "key": "EXTRA_ARGS",
      "label": "Extra Arguments",
      "description": "Additional llama-server CLI flags (space-separated)",
      "required": false,
      "type": "string"
    }
  ],
